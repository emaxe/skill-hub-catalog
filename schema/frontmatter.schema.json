{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skill-hub.dev/schema/frontmatter.schema.json",
  "title": "SKILL.md Frontmatter",
  "description": "Schema for validating SKILL.md frontmatter in Skill-Hub",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique kebab-case identifier for the skill",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "description": "Short description of what the skill does",
      "minLength": 10
    },
    "tags": {
      "type": "array",
      "description": "Tags for categorizing the skill",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "type": "string",
      "description": "Author of the skill"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the skill",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "scope": {
      "type": "string",
      "description": "Where the skill can be used",
      "enum": ["global", "project", "both"],
      "default": "global"
    },
    "platforms": {
      "type": "array",
      "description": "Supported AI coding platforms",
      "items": {
        "type": "string",
        "enum": ["claude-code", "cursor", "gemini", "codex"]
      }
    },
    "dependencies": {
      "type": "array",
      "description": "Other skills this skill depends on",
      "items": {
        "type": "string"
      }
    },
    "language": {
      "type": "string",
      "description": "Programming language the skill targets",
      "default": "any"
    }
  }
}
